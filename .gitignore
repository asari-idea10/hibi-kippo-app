# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated/imported calendar source dumps
/src/data/import/*.source.csv
/src/data/import/chunks/
/src/data/calendar-master-rows.1900-*.json
/src/data/calendar-master/by-year/
/src/data/calendar-note-occurrences.1900-*.json
/src/data/calendar-note-occurrences/by-year/
/src/data/lunar-calendar-1900-*.generated.json
/src/data/lunar-months-1900-*.generated.json

# generated verification workbench
/data-workbench/
/outputs/
