{
  "schemaVersion": "calendar_master_input_schema.v1",
  "description": "★フォーチューンマイレージマスタ > 年月日 を全期間抽出するための入力JSON仕様",
  "rowShape": "array_of_day_rows",
  "requiredKeys": [
    "row",
    "ymLabel",
    "year",
    "month",
    "day",
    "date",
    "yearNumber",
    "monthNumber",
    "dayNumber",
    "sexagenaryNumber",
    "yearPillar",
    "monthPillar",
    "dayPillar",
    "kuubou",
    "solarTerm",
    "setsuiri",
    "daysFromSetsuiri",
    "yearStem",
    "monthStem",
    "dayStem",
    "duplicateYear",
    "duplicateMonth",
    "duplicateDay",
    "yearKyusei",
    "monthKyusei",
    "dayKyusei",
    "ton",
    "yearAnkensatsu",
    "yearGohosatsu",
    "yearSaiha",
    "monthAnkensatsu",
    "monthGohosatsu",
    "monthSaiha",
    "dayAnkensatsu",
    "dayGohosatsu",
    "daySaiha",
    "legacyJunichoku",
    "legacyNijuhachishuku",
    "legacySummary",
    "legacySanrinbou",
    "legacyIchiryumanbaibi",
    "legacyFujoju",
    "legacyHassen",
    "legacyJippoGure",
    "legacyTenichiTenjo",
    "legacyRoujitsu",
    "legacyKasshi",
    "legacyKoushin",
    "legacyShinnyu",
    "legacyTsuchinotoMi",
    "legacyTenshaBi"
  ],
  "optionalKeys": [
    "branch",
    "kasshiHelper",
    "cycle",
    "switchFlag",
    "seasonalBoundaryFlag",
    "yearZokanMain",
    "monthZokanMain",
    "dayZokanMain",
    "yearZokanMiddle",
    "monthZokanMiddle",
    "dayZokanMiddle",
    "yearZokanExtra",
    "monthZokanExtra",
    "dayZokanExtra",
    "doyoFlag",
    "doyoLabel"
  ],
  "booleanFlagKeys": [
    "legacySanrinbou",
    "legacyIchiryumanbaibi",
    "legacyFujoju",
    "legacyHassen",
    "legacyJippoGure",
    "legacyTenichiTenjo",
    "legacyRoujitsu",
    "legacyKasshi",
    "legacyKoushin",
    "legacyShinnyu",
    "legacyTsuchinotoMi",
    "legacyTenshaBi"
  ],
  "dateKey": "date",
  "rowKey": "row",
  "rules": {
    "dateFormat": "YYYY-MM-DD",
    "sort": "date_ascending",
    "duplicates": "error",
    "missingDates": "error_when_range_is_supplied",
    "booleanFlags": ["1", "0", "", 1, 0, true, false],
    "blankCell": ""
  },
  "futureMasterPolicy": {
    "doNotAddUnfinishedColumns": true,
    "useSeparateMasterForMeanings": true,
    "useSeparateMasterForZassetsu": true,
    "useSeparateMasterForZokanMethods": true
  }
}
