{
  "schemaVersion": "calendar_note_generation_input_policy.v0",
  "targetRange": {
    "startYear": 1900,
    "endYear": 2050,
    "futureExtension": [2100, 2150]
  },
  "output": {
    "directory": "src/data/calendar-notes/by-year",
    "schemaVersion": "calendar_note_occurrences.v0",
    "splitByYear": true
  },
  "sources": {
    "legacySpreadsheet": {
      "id": "legacy_spreadsheet",
      "label": "★フォーチューンマイレージマスタ > 年月日",
      "priority": "primary_initial_source",
      "note": "既存の暦注判定を失わないため、1900〜2050拡張の初期入力として優先する。"
    },
    "solarTerms": {
      "id": "solar_terms_verified",
      "path": "src/data/solar-terms-1900-2050.verified.json",
      "priority": "calculation_source",
      "note": "土用、節分、彼岸、八十八夜など太陽暦・節入り起算の暦注に使う。"
    },
    "lunarCalendar": {
      "id": "lunar_calendar_generated",
      "path": "src/data/lunar-calendar/by-year",
      "priority": "calculation_source",
      "note": "旧暦、六曜、旧暦由来行事、不成就日検算に使う。"
    },
    "sexagenary": {
      "id": "sexagenary_calendar",
      "priority": "legacy_then_calculated",
      "note": "甲子、庚申、己巳、八専、十方暮、天一天上など干支番号由来の暦注に使う。"
    },
    "manualAlmanac": {
      "id": "manual_almanac",
      "priority": "verification_source",
      "note": "手元万年暦で重要年・重要日のサンプリング検証を行う。"
    },
    "koyomiPage": {
      "id": "koyomi_page",
      "label": "こよみのページ 暦注計算",
      "url": "https://koyomi8.com/sub/rekicyuu.html",
      "priority": "golden_reference",
      "note": "十二直・二十八宿・主要選日の検証正本として扱う。計算式で生成した結果はこの出力に寄せて照合する。"
    }
  },
